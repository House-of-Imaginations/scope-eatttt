DATABASE_URL=postgres://app:app@localhost:6432/app
DATABASE_DIRECT_URL=postgres://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379
PLACES_PROVIDER=fake
OCR_PROVIDER=fake
GOOGLE_MAPS_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-48
BETTER_AUTH_URL=http://localhost:5173
PROMOTE_THRESHOLD=2
REJECT_STREAK=5
RADIUS_BASE_M=500
RADIUS_STEP_M=500
RADIUS_CAP_M=3000
POLL_TIMER_MS=300000
PLACES_CACHE_TTL_S=1800
RATE_LIMIT_ENABLED=
TRUSTED_IP_HEADER=
# Set to "1" to bypass the real backend and use the in-memory mock API (UI dev / CI)
# Set to "0" (or leave empty) to use the real backend (Postgres + Redis + worker).
# Real multi-client E2E (F1.6): playwright.real.config.ts overrides this to "0"
# and starts a separate dev server on port 5174 — never edit this file for that.
PUBLIC_USE_MOCK=
