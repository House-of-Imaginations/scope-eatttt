{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "include": [
      "apps/**/*.ts",
      "apps/**/*.js",
      "apps/**/*.json",
      "packages/**/*.ts",
      "packages/**/*.js",
      "packages/**/*.json"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.svelte-kit/**",
      "**/migrations/**",
      "**/build/**",
      "**/.omc/**",
      "packages/db/src/schema/auth.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "include": ["**/*.svelte"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    }
  ]
}
